        "reviews": [
            {
                "title": "Thomas Winkel",
                "reviewContent": "Koops Makelaardij Leiden is een zeer professionele organisatie met oog voor de klant. Vriendelijk, behulpzaam en gedegen, zonder poespas. Een aanrader.",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Jane Blackshaw",
                "reviewContent": "Ik ben zeer te spreken over Koops Makelaardij Leiden. Uitstekend, vriendelijk en professioneel geholpen tijdens het verhuur proces.",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Nico Smid",
                "reviewContent": "Communicatie loopt erg goed, professionele aanpak en vriendelijk personeel. Het verhuren van mijn woning wordt echt volledig ontzorgt.",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Katinka Jansen",
                "reviewContent": "Mijn woning is vorig jaar via Koops in de verhuur genomen. Binnen korte tijd hebben zij een geschikte huurder voor de woning gevonden. Het beheer verloopt prima, duidelijke communicatie over lopende zaken en helder inzicht in financiële zaken.",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Jeroen Snel",
                "reviewContent": "De medewerkers van Koops Makelaardij hebben snel een nieuwe huurder gevonden voor ons appartement in Amsterdam. Ze beschikken over een groot netwerk. De afstemming van de nieuwe verhuur verliep heel voorspoedig en kleine problemen werden snel opgelost...",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Danielle Mahazri, Amsterdam",
                "reviewContent": "Geholpen door Edwin en collega's. Allemaal super vriendelijk en professioneel. Snelle service, afspraken worden nagekomen en blij met de soepele communicatie. Een aanrader!",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Marc Behetre",
                "reviewContent": "Het was een genoegen om met hen samen te werken, een echte steun tijdens het hele proces. Zowel verhuurders als huurders zijn bij dit bureau in goede handen.",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Rogier Westhuis, Haarlem",
                "reviewContent": "Zeer prettige makelaar en goed begeleid tijdens de verhuur van mijn woning. Binnen 10 dagen een goede huurder gevonden.",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Mahesh Chinthaka",
                "reviewContent": "Koops Makelaardij is door de verhuurder ingehuurd als makelaar van mijn nieuwe huurwoning. Service was geweldig. Thomas was zo responsief en maakte alles duidelijk en soepel. Thomas zorgde voor een probleemloze service. Sterk aanbevolen! Ik wil Thomas en het team bedanken en veel succes wensen!",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Wouter Spit",
                "reviewContent": "Prettig bedrijf om zaken mee te doen. Ik verhuur via hen een appartement en dat tot volle tevredenheid: ze reageren snel, communiceren duidelijk, screenen de huurders goed: gewoon zoals je het wilt!",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Leo vd S",
                "reviewContent": "Zeer professionele verhuurmakelaar. Goed contact en altijd snel antwoord. Uitstekende service en denken graag mee over hoe een woning optimaal aangeboden kan worden om zo snel mogelijk verhuurd te worden. Ik heb vele soortgelijke partijen gesproken en Koops steekt met kop en schouders er bovenuit, aanrader!",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Marja Arendsen",
                "reviewContent": "Meeste contact met Koops Makelaardij Amsterdam, super vriendelijk, gemotiveerd en service gericht!",
                "__typename": "reviews_default_Entry"
            },
            {
                "title": "Arverladze",
                "reviewContent": "Een hele prettige makelaar om mee samen te werken! Ik had ervaring met andere verhuurmakelaars maar was niet tevreden over hun service. Nu ben ik zeer tevreden, goede (expat)huurders en prettige communicatie.\n\nBedankt Koops!",
                "__typename": "reviews_default_Entry"
            }
        ],
